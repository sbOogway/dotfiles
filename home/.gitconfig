  signingkey = 9E9EAAE5ADB6A717E10C10FF2DEA979EC392CBEF
[credential]
	helper = store
[alias]
  logline = log --graph --pretty=format:'%Cred%h%Creset -%C(auto)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --all
  ll = log --graph --pretty=format:'%Cred%h%Creset %x09 %C(white)%<(30,trunc)%s%Creset %x09 %C(bold blue)%<(15,trunc)%an%Creset %x09 %Cgreen%<(15)%cr%Creset %x09 %C(auto)%d%Creset' --abbrev-commit --all

[commit]
	gpgsign = true
